{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nœud de l'arbre des finances publiques",
  "type": "object",
  "required": [
    "id",
    "label",
    "statut",
    "source",
    "enfants"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]+(\\.[A-Za-z0-9_-]+)+$",
      "description": "Identifiant hiérarchique unique, ex. etat.depenses.RS.150"
    },
    "label": {
      "type": "string",
      "minLength": 3
    },
    "montant": {
      "type": [
        "number",
        "null"
      ],
      "description": "En euros. null si inconnu."
    },
    "annee": {
      "type": [
        "integer",
        "null"
      ],
      "description": "Millésime de la donnée (jamais mélanger silencieusement les années)."
    },
    "statut": {
      "enum": [
        "confirme",
        "estime",
        "inconnu"
      ],
      "description": "confirme = extrait tel quel d'une source officielle ; estime = ordre de grandeur à raffiner ; inconnu = la donnée n'existe pas publiquement"
    },
    "description": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": [
        "nom",
        "url",
        "producteur",
        "consulte_le"
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "producteur": {
          "type": "string"
        },
        "licence": {
          "type": "string"
        },
        "consulte_le": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "maj": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date de dernière mise à jour du jeu de données source (affichée à côté du montant). null si non renseignée — à compléter."
        }
      }
    },
    "inconnu": {
      "type": "object",
      "required": [
        "quoi",
        "contact"
      ],
      "properties": {
        "quoi": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "a_completer": {
      "type": "object",
      "required": [
        "note"
      ],
      "properties": {
        "note": {
          "type": "string"
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "enfants": {
      "type": "array",
      "items": {
        "$ref": "#"
      }
    }
  }
}